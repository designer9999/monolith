{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MONOLITH",
  "mainBinaryName": "monolith",
  "version": "0.1.6",
  "identifier": "com.radionica.monolith",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MONOLITH",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost https://api.github.com https://api.vercel.com https://api.cloudflare.com https://api.stripe.com https://api.openai.com https://api.anthropic.com; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5RDQ2NDQyQzg3ODE0NkEKUldScUZIaklRbVRVR1VjYUFUdFZDU25QQTJwMlNkZnU1Z09lVEpuMzZZRTVSd1NvaGErZ05EbXgK",
      "endpoints": [
        "https://github.com/designer9999/monolith/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
