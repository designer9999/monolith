{
  "name": "monolith",
  "private": true,
  "version": "0.1.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "gui": "tauri dev --no-watch",
    "gui:watch": "tauri dev",
    "mobile:android:init": "scripts\\android-env.bat tauri android init",
    "mobile:android:dev": "scripts\\android-env.bat tauri android dev --open",
    "mobile:android:build": "scripts\\android-env.bat tauri android build",
    "mobile:android:build:phone": "scripts\\android-env.bat tauri android build --target aarch64 --apk --split-per-abi",
    "tauri": "tauri",
    "rust:fmt": "cmd.exe /C \"cd src-tauri && cargo fmt --check\"",
    "rust:test": "cmd.exe /C \"cd src-tauri && cargo test\"",
    "rust:clippy": "cmd.exe /C \"cd src-tauri && cargo clippy --all-targets -- -D warnings\"",
    "check": "npm run typecheck && npm run build && npm run rust:fmt && npm run rust:test && npm run rust:clippy",
    "release:set-version": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\set-version.ps1",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\release-windows.ps1",
    "release:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\release-windows.ps1 -Publish"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-barcode-scanner": "^2.4.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.22.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  }
}
