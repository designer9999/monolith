# GitHub personal access token used by release scripts.
# Required scopes for classic PAT: repo/public_repo for releases.
GITHUB=

# Optional. Defaults to designer9999/monolith.
GITHUB_REPOSITORY=designer9999/monolith

# Local updater signing key. Keep the real .tauri/monolith.key private.
TAURI_SIGNING_PRIVATE_KEY=.tauri\monolith.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
