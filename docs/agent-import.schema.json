{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/designer9999/monolith/docs/agent-import.schema.json",
  "title": "MONOLITH Agent Import Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "source": {
      "type": "string",
      "maxLength": 512
    },
    "defaultProjectId": {
      "type": "string",
      "maxLength": 80
    },
    "defaultProjectName": {
      "type": "string",
      "maxLength": 80
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "env": {
      "type": "string",
      "enum": ["production", "staging", "dev", "all"]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "value": {
          "type": "string",
          "maxLength": 65536
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId"],
      "properties": {
        "projectId": {
          "type": "string",
          "maxLength": 80
        },
        "projectName": {
          "type": "string",
          "maxLength": 80
        },
        "templateId": {
          "type": "string",
          "enum": [
            "supabase",
            "google",
            "github",
            "vercel",
            "stripe",
            "cloudflare",
            "aws",
            "openai",
            "postgres",
            "shopify",
            "smtp",
            "ssh",
            "login",
            "apple",
            "mega",
            "topaz",
            "huggingface",
            "instagram",
            "domain",
            "card",
            "note",
            "prisma",
            "claude",
            "resend",
            "runpod",
            "zeroid"
          ]
        },
        "label": {
          "type": "string",
          "maxLength": 80
        },
        "env": {
          "$ref": "#/$defs/env"
        },
        "expiresAt": {
          "$ref": "#/$defs/date"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "totpSecret": {
          "type": "string",
          "maxLength": 256
        },
        "source": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  }
}
